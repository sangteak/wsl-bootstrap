# 이 파일을 ~/.peach.local.mk 로 복사해 본인 환경 값으로 채운다(저장소 커밋 금지):
#   cp ~/.peach/peach.local.mk.example ~/.peach.local.mk
# Makefile 이 -include 로 로드하며, 여기 설정한 값이 Makefile 기본값을 덮어쓴다.

AWS_PROFILE := your-aws-profile
AWS_REGION  := ap-northeast-2
EKS_CLUSTER := your-eks-cluster-name
DOCKER_NS   := your-dockerhub-namespace
AGONES_DIR  := $(HOME)/agones2
