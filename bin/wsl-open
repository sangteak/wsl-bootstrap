#!/bin/sh
# WSL: URL을 Windows 기본 브라우저로 연다. 'aws login' 등의 BROWSER 오프너.
#
# 왜 PowerShell Start-Process인가:
#   - explorer.exe는 폴더/파일용이라 쿼리스트링(&·?·%) 붙은 URL을 못 열고 기본 폴더(문서)를 띄운다.
#   - cmd 'start'는 '&'를 명령 구분자로 오인할 수 있다.
#   - wslview(wslu 3.2.3)는 WSLInterop-late를 못 알아봐 interop 꺼짐으로 오판한다.
#   → Start-Process에 URL을 작은따옴표 문자열로 넘기면(셸 재파싱 없음) &·%·? 모두 안전하게 열린다.
# (URL에 작은따옴표는 없음 — aws의 URL은 퍼센트 인코딩됨)
powershell.exe -NoProfile -Command "Start-Process '$1'" >/dev/null 2>&1
exit 0
