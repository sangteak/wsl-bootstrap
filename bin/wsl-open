#!/bin/sh
# WSL: URL/경로를 Windows 기본 앱(브라우저)으로 연다 — interop의 explorer.exe(ShellExecute).
# 'aws login' 등의 BROWSER 오프너로 사용한다.
#
# 왜 wslview가 아니라 이걸 쓰나:
#   - 최신 WSL은 systemd와 공존하려 interop을 'WSLInterop-late'로 등록하는데,
#     Ubuntu apt의 wslu 3.2.3은 옛 이름 'WSLInterop'만 확인해 "interop 꺼짐"으로 오판한다.
#   - cmd.exe 'start'는 WSL 경로에서 UNC 경고를 내고 '&' 들어간 URL을 깨뜨릴 수 있다.
#   - explorer.exe는 인자를 ShellExecute로 그대로 넘겨 URL을 안전하게 연다(단, 성공해도 exit 1이라 0으로 정규화).
explorer.exe "$1" >/dev/null 2>&1
exit 0
